{
  "name": "leda-monitor",
  "version": "0.1.0",
  "private": true,
  "description": "L.E.D.A — monitoramento local da saúde das suas aplicações.",
  "main": "electron/main.cjs",
  "author": "Leandro Alencar",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "dev:web": "vite --host 127.0.0.1",
    "start": "electron .",
    "build": "vite build",
    "build:win": "npm run build && electron-builder --win nsis",
    "test": "node --test tests/*.test.mjs"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "vite": "^6.0.5",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.alencarleandro.leda",
    "productName": "L.E.D.A",
    "asar": true,
    "files": ["dist/**/*", "electron/**/*", "package.json"],
    "directories": { "output": "release" },
    "win": {
      "target": "nsis",
      "artifactName": "LEDA-Setup-${version}.${ext}",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "L.E.D.A"
    }
  }
}
